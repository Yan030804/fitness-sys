<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.fitness.system.mapper.SysRoleMapper">

    <resultMap id="SysRoleResultMap" type="com.example.fitness.system.entity.SysRole">
        <id property="id" column="id"/>
        <result property="roleCode" column="role_code"/>
        <result property="roleName" column="role_name"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="selectById" resultMap="SysRoleResultMap">
        SELECT *
        FROM sys_role
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectByRoleCode" resultMap="SysRoleResultMap">
        SELECT *
        FROM sys_role
        WHERE role_code = #{roleCode}
        LIMIT 1
    </select>
</mapper>
