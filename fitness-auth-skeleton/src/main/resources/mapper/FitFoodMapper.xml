<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.fitness.food.mapper.FitFoodMapper">

    <resultMap id="FitFoodResultMap" type="com.example.fitness.food.entity.FitFood">
        <id property="id" column="id"/>
        <result property="foodName" column="food_name"/>
        <result property="category" column="category"/>
        <result property="caloriesPer100g" column="calories_per_100g"/>
        <result property="proteinPer100g" column="protein_per_100g"/>
        <result property="fatPer100g" column="fat_per_100g"/>
        <result property="carbPer100g" column="carb_per_100g"/>
        <result property="suitableGoal" column="suitable_goal"/>
        <result property="suitableTime" column="suitable_time"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="FoodColumns">
        id,
        food_name AS foodName,
        category,
        calories_per_100g AS caloriesPer100g,
        protein_per_100g AS proteinPer100g,
        fat_per_100g AS fatPer100g,
        carb_per_100g AS carbPer100g,
        suitable_goal AS suitableGoal,
        suitable_time AS suitableTime,
        description,
        status,
        created_at AS createdAt,
        updated_at AS updatedAt
    </sql>

    <sql id="FoodPageWhere">
        <where>
            status = 1
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="suitableGoal != null and suitableGoal != ''">
                AND suitable_goal = #{suitableGoal}
            </if>
            <if test="suitableTime != null and suitableTime != ''">
                AND suitable_time = #{suitableTime}
            </if>
        </where>
    </sql>

    <sql id="AdminFoodPageWhere">
        <where>
            <if test="foodName != null and foodName != ''">
                AND food_name LIKE CONCAT('%', #{foodName}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="suitableGoal != null and suitableGoal != ''">
                AND suitable_goal = #{suitableGoal}
            </if>
            <if test="suitableTime != null and suitableTime != ''">
                AND suitable_time = #{suitableTime}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </sql>

    <select id="selectById" resultMap="FitFoodResultMap">
        SELECT *
        FROM fit_food
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectDetailById" resultType="com.example.fitness.food.vo.FoodVO">
        SELECT
            <include refid="FoodColumns"/>
        FROM fit_food
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="countPage" resultType="long"
            parameterType="com.example.fitness.food.dto.FoodPageQuery">
        SELECT COUNT(1)
        FROM fit_food
        <include refid="FoodPageWhere"/>
    </select>

    <select id="selectPage" resultType="com.example.fitness.food.vo.FoodVO"
            parameterType="com.example.fitness.food.dto.FoodPageQuery">
        SELECT
            <include refid="FoodColumns"/>
        FROM fit_food
        <include refid="FoodPageWhere"/>
        ORDER BY id DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countAdminPage" resultType="long"
            parameterType="com.example.fitness.admin.food.dto.AdminFoodPageQuery">
        SELECT COUNT(1)
        FROM fit_food
        <include refid="AdminFoodPageWhere"/>
    </select>

    <select id="selectAdminPage" resultType="com.example.fitness.food.vo.FoodVO"
            parameterType="com.example.fitness.admin.food.dto.AdminFoodPageQuery">
        SELECT
            <include refid="FoodColumns"/>
        FROM fit_food
        <include refid="AdminFoodPageWhere"/>
        ORDER BY id DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <insert id="insert" parameterType="com.example.fitness.food.entity.FitFood"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO fit_food (
            food_name,
            category,
            calories_per_100g,
            protein_per_100g,
            fat_per_100g,
            carb_per_100g,
            suitable_goal,
            suitable_time,
            description,
            status,
            created_at,
            updated_at
        ) VALUES (
            #{foodName},
            #{category},
            #{caloriesPer100g},
            #{proteinPer100g},
            #{fatPer100g},
            #{carbPer100g},
            #{suitableGoal},
            #{suitableTime},
            #{description},
            #{status},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <update id="updateById" parameterType="com.example.fitness.food.entity.FitFood">
        UPDATE fit_food
        SET food_name = #{foodName},
            category = #{category},
            calories_per_100g = #{caloriesPer100g},
            protein_per_100g = #{proteinPer100g},
            fat_per_100g = #{fatPer100g},
            carb_per_100g = #{carbPer100g},
            suitable_goal = #{suitableGoal},
            suitable_time = #{suitableTime},
            description = #{description},
            status = #{status},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <update id="updateStatusById">
        UPDATE fit_food
        SET status = #{status},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>
</mapper>
